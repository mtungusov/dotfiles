{
    "editor.fontFamily": "'Maple Mono NF',Menlo,Monaco,'Courier New',monospace",
    "editor.fontSize": 16,
    "editor.fontLigatures": "'ss03'",
    "editor.minimap.enabled": false,
    "editor.semanticTokenColorCustomizations": {
        "rules": {
            "interface": {
            "italic": true
            },
            "selfParameter": {
            "italic": true
            },
            "keyword": {
            "italic": true
            },
            "*.static": {
            "italic": true
            }
        }
    },
    "editor.tokenColorCustomizations": {
        "comments": "#aa3300",
        "textMateRules": [
            {
                "scope": [
                    "constant.language.undefined",
                    "constant.language.null",
                    "constant.language.nullptr",
                    "meta.type keyword.operator.expression.typeof",
                    "meta.type keyword.operator.expression.keyof",
                    "keyword.control",
                    "keyword.function",
                    "keyword.operator.new",
                    "keyword.operator.borrow.and.rust",
                    "storage.type",
                    "storage.modifier",
                    "variable.language.this",
                    "markup.italic"
                ],
                "settings": {
                    "fontStyle": "italic"
                }
            }
        ]
    },
    "editor.unicodeHighlight.allowedCharacters": {
        "с": true
    },
    "explorer.confirmDelete": false,
    "extensions.experimental.affinity": {
        "asvetliakov.vscode-neovim": 1
    },
    "go.lintTool": "golangci-lint",
    "go.toolsManagement.autoUpdate": true,
    "redhat.telemetry.enabled": false,
    "terminal.integrated.fontSize": 14,
    "terminal.integrated.fontLigatures.enabled": true,
    "update.showReleaseNotes": false,
    "vscode-neovim.compositeKeys": {
        "jk": {
            // Use lua to execute any logic
            "command": "vscode-neovim.lua",
            "args": [
                [
                    "local code = require('vscode')",
                    "code.action('vscode-neovim.escape')",
                    "code.action('workbench.action.files.save')",
                ],
            ],
        },
    },
    "workbench.colorTheme": "Maple Light",
    "workbench.startupEditor": "none",
    "zenMode.centerLayout": false,
    "zenMode.hideLineNumbers": false,
    "zenMode.showTabs": "single",
}
