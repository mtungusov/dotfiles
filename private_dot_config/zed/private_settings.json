// Zed settings
{
  "vim_mode": true,
  // --- Langs and LSP ---
  //"inlay_hints": { "enabled": true },
  "languages": {
    "Go": {
      "format_on_save": "on",
      "language_servers": ["gopls", "golangci-lint"],
    },
    "Python": {
      "indent_guides": {
        "enabled": true,
      },
    },
    "Ruby": {
      "language_servers": ["ruby-lsp", "!solargraph", "!rubocop", "..."],
    },
  },
  "lsp": {
    "golangci-lint": {
      "initialization_options": {
        "command": ["golangci-lint", "run", "--out-format", "json", "--issues-exit-code=1"],
      },
    },
    "ruby-lsp": {
      "initialization_options": {
        "enabledFeatures": {
          "diagnostics": false,
          "onTypeFormatting": false,
        },
      },
    },
  },
  // --- Langs and LSP End ---
  "file_scan_exclusions": [
    "**/.git",
    "**/.venv",
    "**/node_modules",
    "**/dist",
    "**/build",
    "**/target",
    "**/.rope*",
    "**/*_cache",
    "**/__pycache__",
    "**/.*-version",
    "**/.DS_Store",
  ],
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "indent_guides": {
    "enabled": false,
  },
  "preferred_line_length": 140,
  "scrollbar": { "show": "auto" },
  "soft_wrap": "bounded",
  "tabs": {
    "git_status": false,
  },
  "terminal": {
    "dock": "right",
    "font_size": 14,
    "line_height": "standard",
    "toolbar": {
      "breadcrumbs": false,
    },
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  // UI: font, theme
  "buffer_font_family": "Maple Mono NF",
  "buffer_font_fallbacks": [".ZedMono"],
  "buffer_font_size": 16,
  "buffer_font_features": {
    "calt": false,
  },
  "buffer_line_height": "comfortable",
  "ui_font_family": ".ZedSans",
  "ui_font_size": 10,
  // Theme
  "theme": {
    "mode": "light",
    "light": "Modus Operandi Tinted",
    "dark": "VSCode Dark Modern",
  },
  "experimental.theme_overrides": {
    // "editor.background": "#f8faf8",
    "syntax": {
      "comment": {
        "font_style": "normal",
      },
    },
  },
}
